---
interface Props {
	placement?: 'mid' | 'end';
}

const { placement = 'mid' } = Astro.props;
const fieldId = `pulse-email-${placement}`;
const isEnd = placement === 'end';
---

<section class="newsletter-signup pulse-signup" aria-labelledby={`${fieldId}-heading`}>
	<div class="newsletter-copy">
		<p class="newsletter-kicker">This week in engineering</p>
		<h2 id={`${fieldId}-heading`}>{isEnd ? 'Get next week’s edition.' : 'Want next week’s stories?'}</h2>
		<p>
			{isEnd
				? 'If this saved you time, I’ll send the next edition directly to you.'
				: 'A quick briefing on what senior engineers and engineering managers are arguing about—and why it matters.'}
		</p>
	</div>
	<form
		action="https://buttondown.com/api/emails/embed-subscribe/mazaika"
		method="post"
		class="embeddable-buttondown-form"
	>
		<label for={fieldId}>Email address</label>
		<div class="newsletter-fields">
			<input type="email" name="email" id={fieldId} autocomplete="email" placeholder="you@company.com" required />
			<input type="hidden" name="embed" value="1" />
			<button type="submit">Send me next week’s edition</button>
		</div>
		<p class="newsletter-note">One email per edition. Unsubscribe anytime.</p>
	</form>
</section>